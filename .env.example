# Example .env for local development
# Copy this file to .env and fill values before running locally.

# Google AI API key (only required if you want AI-generated personality maps locally).
# In production this must be set in the environment.
GOOGLE_API_KEY=REPLACE_ME

# Flask environment
FLASK_ENV=development

# Optional: local sqlite path used by tests or dev (will be overridden by DATABASE_URL env in tests)
DATABASE_URL=sqlite:///dev.db

# Optional: when deploying to Vercel set VERCEL=1 or VERCEL_ENV=production
VERCEL=

# Upload folder (relative to project root)
UPLOAD_FOLDER=tmp/uploads

# Secret key (you can leave default during development)
SECRET_KEY=tebak-wajah-secret
